# Frontend: copy values into apps/web/.env.local or set them in Vercel.
VITE_GOOGLE_API_KEY=api-key-here
VITE_DEMO_MODE=true

# Backend local development: export these before running Rails if you want to
# override the Docker Postgres defaults in apps/api/config/database.yml.
DB_HOST=127.0.0.1
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_PORT=55432
DEMO_MODE=true
DEMO_USER_EMAIL=beetman@shrutefarms.com

# Backend production: set these as Fly.io secrets.
RAILS_MASTER_KEY=replace-with-config-master-key
SECRET_KEY_BASE=replace-with-bin-rails-secret
